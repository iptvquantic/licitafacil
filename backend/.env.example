# ============================================
# LicitaFácil — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================

# App
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://licitafacil.vercel.app

# JWT (gere com: openssl rand -base64 32)
JWT_SECRET=GERE_UMA_STRING_ALEATORIA_DE_32_CHARS_AQUI

# Banco de Dados — Supabase (postgresql)
DATABASE_URL=postgresql://postgres:SENHA@db.PROJETO.supabase.co:5432/postgres

# IA — OpenRouter
OPENROUTER_API_KEY=SUA_CHAVE_OPENROUTER_AQUI
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Storage — Cloudflare R2
R2_ACCOUNT_ID=SEU_ACCOUNT_ID
R2_ACCESS_KEY_ID=SEU_ACCESS_KEY
R2_SECRET_ACCESS_KEY=SEU_SECRET_KEY
R2_BUCKET=licitafacil-catalogos
R2_PUBLIC_URL=https://SEU_BUCKET.r2.dev

# Redis — Railway ou Upstash (opcional, para filas)
REDIS_URL=redis://localhost:6379

# Email — opcional para reset de senha
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua-senha-de-app
EMAIL_FROM=LicitaFácil <noreply@licitafacil.com.br>

# Limites
MAX_FILE_SIZE_MB=50
TRIAL_DAYS=15
